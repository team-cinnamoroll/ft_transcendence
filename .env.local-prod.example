# =============================================
# tracen: Local production-like environment variables
# - [config] は設定パラメータ、[secret] は機密情報です
# - 値はローカル実行向けの安全なデフォルトです
# =============================================

# --- Node/Runtime ------------------------------------------
# [config] production / development など
NODE_ENV=production

# --- Local registry (https://registry.tracen.local:5000) ----
# [config] registry listen address
REGISTRY_HTTP_ADDR=0.0.0.0:5000

# [config] registry TLS certificate path (in container)
REGISTRY_HTTP_TLS_CERTIFICATE=/etc/registry/tls/tls.crt

# [secret] registry TLS private key path (in container)
REGISTRY_HTTP_TLS_KEY=/etc/registry/tls/tls.key

# --- Database (PostgreSQL) ---------------------------------
# [config] PostgreSQL database name
POSTGRES_DB=tracen

# [config] PostgreSQL user
POSTGRES_USER=tracen

# [secret] PostgreSQL password
POSTGRES_PASSWORD=tracen

# [config] Backend database connection URL (used by Drizzle/postgres.js)
DATABASE_URL=postgresql://tracen:tracen@db:5432/tracen

# [config] Run DB migrations automatically on backend startup
RUN_MIGRATIONS=true

# --- Backend (Hono) ----------------------------------------
# [config] backend listen port (nginx upstream)
BACKEND_PORT=8443

# [config] backend TLS certificate path (in container)
BACKEND_TLS_CERT_PATH=/etc/tracen/certs/tls.crt

# [secret] backend TLS private key path (in container)
BACKEND_TLS_KEY_PATH=/etc/tracen/certs/tls.key

# --- Frontend-BFF (Next.js custom HTTPS server) ------------
# [config] frontend-bff listen port (nginx upstream)
FRONTEND_PORT=3443

# [config] frontend-bff TLS certificate path (in container)
FRONTEND_TLS_CERT_PATH=/etc/tracen/certs/tls.crt

# [secret] frontend-bff TLS private key path (in container)
FRONTEND_TLS_KEY_PATH=/etc/tracen/certs/tls.key

# [config] mkcert CA certificate path (in container)
# - BFF(server) が backend を HTTPS で呼ぶための信頼ストアとして使用
NODE_EXTRA_CA_CERTS=/etc/tracen/certs/ca.crt

# --- BFF(server) -> Backend API ----------------------------
# [config] BFF(Next server) から backend(Hono) を呼ぶためのベースURL
APP_API_BASE_URL=https://backend.tracen.local:8443

# --- Frontend(browser) -> BFF API --------------------------
# [config/public] ブラウザから BFF API を呼ぶためのベースURL
# - NEXT_PUBLIC_ はクライアントバンドルに公開されます
# - これは build 時に注入される必要があります（NEXT_PUBLIC_*）
NEXT_PUBLIC_BFF_API_BASE_URL=https://tracen.local/api
