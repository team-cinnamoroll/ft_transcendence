# =============================================
# tracen: Development environment variables
# - [config] は設定パラメータ、[secret] は機密情報です
# =============================================

# --- Database (PostgreSQL) ---------------------------------
# [config] Dev PostgreSQL database name
POSTGRES_DB=tracen

# [config] Dev PostgreSQL user
POSTGRES_USER=tracen

# [secret] Dev PostgreSQL password (ローカル開発用)
POSTGRES_PASSWORD=tracen

# --- Backend (Hono) ----------------------------------------
# [config] Backend database connection URL (used by Drizzle/postgres.js)
DATABASE_URL=postgresql://tracen:tracen@db:5432/tracen

# [config] Run DB migrations automatically on backend startup
RUN_MIGRATIONS=true

# --- BFF(server) -> Backend API ----------------------------
# [config] BFF(Next server) から backend(Hono) を呼ぶためのベースURL
# - dev は Docker ネットワーク内で backend サービスへ到達します
APP_API_BASE_URL=http://backend:8000

# --- Frontend(browser) -> BFF API --------------------------
# [config/public] ブラウザから BFF API を呼ぶためのベースURL
# - NEXT_PUBLIC_ はクライアントバンドルに公開されます
# - dev は nginx 経由の入口(http://localhost:8080)を想定
NEXT_PUBLIC_BFF_API_BASE_URL=http://localhost:8080/api
